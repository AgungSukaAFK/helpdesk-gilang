# Update these with your Supabase details from your project settings > API
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_OR_ANON_KEY=your-anon-key

# Service role key — dipakai fitur reset password admin (Manajemen User).
# RAHASIA: menembus seluruh RLS. Jangan diberi prefix NEXT_PUBLIC dan jangan
# pernah di-commit; isi hanya di .env lokal / environment variable hosting.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
